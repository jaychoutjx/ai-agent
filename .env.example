# ============================================
# 应用基础配置
# ============================================
APP_NAME=AI-Knowledge-Base
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8800

# ============================================
# 阿里云百炼（DashScope）大模型平台
# 注册地址: https://bailian.console.aliyun.com
# 通过兼容 OpenAI 协议端点统一访问 Qwen 系列模型
# ============================================
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- Chat 模型 ----
# qwen-plus: 性价比首选（推荐日常对话）
# qwen-max:  最强模型（复杂任务）
# qwen-turbo:速度最快、价格最便宜
QWEN_CHAT_MODEL=qwen-plus

# ---- 推理模型（可选） ----
# qwq-plus 是 Qwen 团队的深度推理模型（类似 DeepSeek-R1）
QWEN_REASONER_MODEL=qwq-plus

# ---- Embedding 模型 ----
# text-embedding-v3: Qwen 自家最新版，1024 维
QWEN_EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ---- Reranker 模型 ----
# gte-rerank-v2: 阿里达摩院出品
QWEN_RERANKER_MODEL=gte-rerank-v2

# ============================================
# 向量数据库（Milvus）
# ============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=aikb_knowledge

# ============================================
# 关系数据库（PostgreSQL）
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aikb
POSTGRES_PASSWORD=aikb_dev_password
POSTGRES_DB=aikb
DATABASE_URL=postgresql+asyncpg://aikb:aikb_dev_password@localhost:5432/aikb

# ============================================
# Redis（缓存 + 语义缓存）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ============================================
# Langfuse（可观测性）
# 自托管或 https://cloud.langfuse.com 注册
# ============================================
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# Tavily 联网搜索（Agent web_search 工具）
# 注册地址: https://tavily.com
# 免费每月 1000 次搜索，专为 LLM 设计的搜索 API
# 留空则使用 mock 版本（仅演示）
# ============================================
TAVILY_API_KEY=

# ============================================
# 鉴权（开发期可不改）
# ============================================
JWT_SECRET_KEY=change-this-to-a-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ============================================
# 文件上传
# ============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3300,http://127.0.0.1:3300

# ============================================
# 寝室群聊 RAG（私密功能，可选）
# ============================================
# 用导入脚本把微信群聊 JSON 喂入向量库，前端切到"寝室"模式问答 / 总结 / 风格模仿
# 留空 DORM_ACCESS_TOKEN 表示该功能整体关闭（前端入口隐藏）
DORM_COLLECTION=aikb_dorm_messages
DORM_ACCESS_TOKEN=
DORM_OWNER_NAME=叶湘伦jay
DORM_SESSION_GAP_MINUTES=30
DORM_MAX_MSGS_PER_CHUNK=30
